# Postgres
DATABASE_URL="postgresql://veritix:veritix@localhost:5432/veritix?schema=public"

# JWT signing secret - generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"

# Stacks network: testnet | mainnet
STACKS_NETWORK="testnet"

# Hiro API base (override only if self-hosting)
HIRO_API_TESTNET="https://api.testnet.hiro.so"
HIRO_API_MAINNET="https://api.hiro.so"

# Platform escrow wallet that receives ticket payments
ESCROW_ADDRESS_TESTNET=""
ESCROW_ADDRESS_MAINNET=""

# Exposed to the browser for ticket purchase (must match the server-side escrow above)
NEXT_PUBLIC_ESCROW_ADDRESS_TESTNET=""
NEXT_PUBLIC_ESCROW_ADDRESS_MAINNET=""

# Dev-only: skip wallet signature verification (NEVER set true in prod)
DEV_AUTH_BYPASS="false"

# Dev-only: skip on-chain payment verification; tickets become Valid immediately
DEV_PAYMENT_BYPASS="false"
NEXT_PUBLIC_DEV_PAYMENT_BYPASS="false"
