// Veritix backend schema
// Wallet address is the primary identifier for users.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventCategory {
  Music
  Tech
  Sports
  Art
  Conference
  Workshop
}

enum EventStatus {
  Active
  SoldOut
  Cancelled
  Ended
}

enum TicketStatus {
  Pending
  Valid
  Used
  Cancelled
}

model User {
  id          String   @id @default(cuid())
  address     String   @unique
  name        String?
  bio         String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events        Event[]
  tickets       Ticket[]
  disbursements Disbursement[]
}

model Event {
  id            String        @id @default(cuid())
  title         String
  description   String
  category      EventCategory
  date          DateTime
  location      String
  image         String
  price         Decimal       @db.Decimal(20, 6)
  network       String        @default("stacks") // stacks | bitcoin
  ticketsTotal  Int
  ticketsSold   Int           @default(0)
  status        EventStatus   @default(Active)

  organizerId   String
  organizer     User          @relation(fields: [organizerId], references: [id])

  tickets        Ticket[]
  rewardConfig   RewardConfig?
  disbursements  Disbursement[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([organizerId])
  @@index([date])
}

model Ticket {
  id          String       @id @default(cuid())
  eventId     String
  event       Event        @relation(fields: [eventId], references: [id])
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id])

  // On-chain payment linkage - the proof of registration.
  txId        String       @unique
  txStatus    String       @default("pending") // pending | confirmed | failed
  amountStx   Decimal      @db.Decimal(20, 6)
  paidTo      String       // escrow wallet that received payment
  network     String       // testnet | mainnet

  status      TicketStatus @default(Pending)
  usedAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([eventId])
  @@index([ownerId])
}

model Nonce {
  address   String   @id
  nonce     String
  expiresAt DateTime

  @@index([expiresAt])
}

model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now())
}

model RewardConfig {
  id              String   @id @default(cuid())
  eventId         String   @unique
  event           Event    @relation(fields: [eventId], references: [id])
  tokenPerCheckin Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Disbursement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id])
  amount    Int
  txId      String?
  txStatus  String   @default("pending") // pending | confirmed | failed
  network   String
  type      String                       // event_reward | monthly_bonus
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([eventId])
  @@index([type])
}
