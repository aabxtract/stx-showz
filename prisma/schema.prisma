// Veritix backend schema
// Wallet address is the primary identifier for users.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventCategory {
  Music
  Tech
  Sports
  Art
  Conference
  Workshop
}

enum EventStatus {
  Active
  SoldOut
  Cancelled
  Ended
}

enum TicketStatus {
  Pending
  Valid
  Used
  Cancelled
}

model User {
  id          String   @id @default(cuid())
  address     String   @unique
  name        String?
  bio         String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events  Event[]  @relation("OrganizerEvents")
  tickets Ticket[]
}

model Event {
  id            String        @id @default(cuid())
  title         String
  description   String
  category      EventCategory
  date          DateTime
  location      String
  image         String
  price         Decimal       @db.Decimal(20, 6)
  ticketsTotal  Int
  ticketsSold   Int           @default(0)
  status        EventStatus   @default(Active)

  organizerId   String
  organizer     User          @relation("OrganizerEvents", fields: [organizerId], references: [id])

  tickets       Ticket[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([organizerId])
  @@index([date])
}

model Ticket {
  id          String       @id @default(cuid())
  eventId     String
  event       Event        @relation(fields: [eventId], references: [id])
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id])

  // On-chain payment linkage - the proof of registration.
  txId        String       @unique
  txStatus    String       @default("pending") // pending | confirmed | failed
  amountStx   Decimal      @db.Decimal(20, 6)
  paidTo      String       // escrow wallet that received payment
  network     String       // testnet | mainnet

  status      TicketStatus @default(Pending)
  usedAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([eventId])
  @@index([ownerId])
}

model Nonce {
  address   String   @id
  nonce     String
  expiresAt DateTime

  @@index([expiresAt])
}

model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now())
}
